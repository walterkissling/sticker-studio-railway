# Supply-chain hardening — dependency cooldown.
# Refuse package versions published less than 7 days ago. A trusted package can
# publish a malicious version at any moment; most are caught and yanked within
# hours-to-days, so a 7-day delay filters out the smash-and-grab compromises.
# npm-native since CLI 11.10.0 (Feb 2026); value is in DAYS. Applies when
# resolving deps (npm install); `npm ci` installs locked versions as-is.
#
# Emergency CVE exception (reviewed): to pull a critical fix sooner, run once:
#   npm install <pkg>@<version> --min-release-age=0
# then commit the updated package-lock.json and note why in the commit message.
min-release-age=7
